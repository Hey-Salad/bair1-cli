{
  "name": "@heysalad/bair1",
  "version": "1.0.0",
  "description": "JavaScript SDK and CLI for Bair1 air quality sensor data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
